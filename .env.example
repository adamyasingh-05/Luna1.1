# Copy this file to .env and fill in only what you want to use.
# Everything is optional — Luna1.1 works without any API keys.

# --- Free tier / recommended ---
HF_API_KEY=          # huggingface.co/settings/tokens (free account)
FAL_API_KEY=         # fal.ai (free tier for image + video)

# --- Paid (optional, for higher quality) ---
OPENAI_API_KEY=      # platform.openai.com
REPLICATE_API_KEY=   # replicate.com
MUAPI_API_KEY=       # muapi.ai
